<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="20.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mahbub.bloodbank.bloodbank.HelloController">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>

    <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="title-text" text="DONOR REGISTRATION" />

    <GridPane hgap="10" vgap="15" alignment="CENTER">
        <Label text="Full Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="nameField" promptText="Enter your name" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label text="Mobile:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="mobileField" promptText="017XXXXXXXX" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label text="Password:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <PasswordField fx:id="passField" promptText="••••••••" GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <Label text="Blood Group:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <ComboBox fx:id="bloodGroupCombo" prefWidth="200.0" promptText="Select Group" GridPane.columnIndex="1" GridPane.rowIndex="3" />

        <Label text="District:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
        <ComboBox fx:id="districtCombo" prefWidth="200.0" promptText="Select District" GridPane.columnIndex="1" GridPane.rowIndex="4" />
    </GridPane>

    <HBox alignment="CENTER" spacing="15.0">
        <Button onAction="#onSignupClick" styleClass="primary-button" text="Register Now" />
        <Button onAction="#onBackClick" styleClass="secondary-button" text="Back to Login" />
    </HBox>

    <Label fx:id="statusLabel" styleClass="status-msg" />
</VBox>