<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="20.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mahbub.bloodbank.bloodbank.LoginController">
<padding>
<Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
</padding>

<Text styleClass="title-text" text="BLOOD BANK LOGIN" />

<GridPane alignment="CENTER" hgap="10" vgap="15">
<Label text="Mobile:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
<TextField fx:id="loginMobileField" promptText="Enter Mobile" GridPane.columnIndex="1" GridPane.rowIndex="0" />

<Label text="Password:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
<PasswordField fx:id="loginPassField" promptText="••••••••" GridPane.columnIndex="1" GridPane.rowIndex="1" />
</GridPane>

<HBox alignment="CENTER" spacing="15.0">
<Button onAction="#onLoginClick" styleClass="primary-button" text="Login" />
<Button onAction="#goToSignup" styleClass="secondary-button" text="Create Account" />
</HBox>

<Label fx:id="loginStatusLabel" styleClass="status-msg" />
</VBox>