<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="600.0" prefWidth="900.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mahbub.bloodbank.bloodbank.DashboardController">

    <top>
        <VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #1f2335;">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <Text styleClass="title-text" text="FIND BLOOD DONORS" />
            <HBox alignment="CENTER" spacing="15.0">
                <ComboBox fx:id="searchBloodGroup" promptText="Select Blood Group" prefWidth="180.0" />
                <ComboBox fx:id="searchDistrict" promptText="Select District" prefWidth="180.0" />
                <Button onAction="#onSearchClick" styleClass="primary-button" text="Search Now" />
                <Button onAction="#onLogoutClick" styleClass="secondary-button" text="Logout" />
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="10.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <TableView fx:id="donorTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colName" prefWidth="250.0" text="Donor Name" />
                    <TableColumn fx:id="colGroup" prefWidth="100.0" text="Blood Group" />
                    <TableColumn fx:id="colDistrict" prefWidth="200.0" text="District" />
                    <TableColumn fx:id="colMobile" prefWidth="200.0" text="Contact Number" />
                </columns>
            </TableView>
        </VBox>
    </center>

</BorderPane>